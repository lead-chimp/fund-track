# Ignore environment files to prevent them from affecting the build
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# Ignore development files
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore build artifacts
.next
out

# Ignore testing and coverage
coverage
test-results
playwright-report

# Ignore logs
logs
*.log

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore IDE files
.vscode
.idea
*.swp
*.swo
*~

# Ignore git
.git
.gitignore

# Ignore documentation
README.md
docs

# Ignore development tools
jest.config.js
jest.integration.config.js
jest.setup.js
playwright.config.ts
tsconfig.json
tsconfig.tsbuildinfo

# Ignore docker files
Dockerfile
docker-compose*.yml
.dockerignore

# Ignore backup and temp files
backups
*.tmp
*.temp
