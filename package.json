{
  "name": "fund-track",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma migrate deploy && npx prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e",
    "test:ci": "npm run test:coverage && npm run test:integration",
    "test:coverage:open": "npm run test:coverage && open coverage/lcov-report/index.html",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:force": "FORCE_SEED=true tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "backup:db": "echo 'Database backups are handled by Coolify'",
    "restore:db": "echo 'Database restoration is handled by Coolify'",
    "health:check": "curl -f http://localhost:3000/api/health || exit 1",
    "security:audit": "npm audit --audit-level moderate",
    "security:fix": "npm audit fix"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.13.0",
    "@types/mssql": "^9.1.7",
    "@types/node-cron": "^3.0.11",
    "autoprefixer": "^10.4.21",
    "backblaze-b2": "^1.7.1",
    "bcrypt": "^5.1.1",
    "form-data": "^4.0.4",
    "mailgun.js": "^12.0.3",
    "mssql": "^11.0.1",
    "next": "14.2.5",
    "next-auth": "^4.24.11",
    "node-cron": "^4.2.1",
    "react": "^18",
    "react-dom": "^18",
    "twilio": "^5.8.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/form-data": "^2.2.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "jest-environment-node": "^30.0.5",
    "node-fetch": "^3.3.2",
    "postcss": "^8",
    "prisma": "^6.13.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.1",
    "typescript": "^5"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}